<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>K-12 Federal Compliance Calendar: The Language Firm</title>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,600;0,9..144,700;1,9..144,400&family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
<style>
  :root {
    --dark:     #1B3A4B;
    --accent:   #1A5FA0;
    --amber:    #A85D1A;
    --amber-bg: #F5E0C8;
    --blue-bg:  #D4E6F5;
    --red:      #8B1A2A;
    --red-bg:   #F0D4D8;
    --gray:     #6B7C8A;
    --gray-lt:  #E8EDF1;
    --body:     #333333;
    --bg:       #F2F4F6;
    --white:    #FFFFFF;
  }
 
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg); font-family: 'DM Sans', sans-serif; color: var(--body); line-height: 1.6; }
 
  /* MARQUEE */
  .cal-band { background: var(--dark); padding: 13px 40px; overflow: hidden; white-space: nowrap; }
  .cal-band-inner { display: inline-block; animation: calMarquee 30s linear infinite; }
  @keyframes calMarquee { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
  .cal-band-inner span { font-size: 10px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: rgba(255,255,255,0.35); padding: 0 32px; }
  .cal-band-inner span.hi { color: rgba(255,255,255,0.85); }
 
  /* WRAPPER */
  .cal-wrap { max-width: 960px; margin: 0 auto; padding: 48px 24px 64px; }
 
  /* HEADER */
  .cal-header { margin-bottom: 32px; animation: fadeUp 0.5s ease both 0.05s; }
  .cal-eyebrow { font-size: 10px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: var(--accent); display: flex; align-items: center; gap: 10px; margin-bottom: 14px; }
  .cal-eyebrow::before { content: ''; display: inline-block; width: 22px; height: 2px; background: var(--accent); }
  .cal-title { font-family: 'Fraunces', serif; font-size: clamp(28px, 4vw, 42px); font-weight: 700; color: var(--dark); line-height: 1.15; margin-bottom: 12px; }
  .cal-title em { font-style: italic; font-weight: 300; color: var(--accent); }
  .cal-desc { font-size: 14.5px; color: var(--gray); max-width: 620px; line-height: 1.7; margin-bottom: 18px; }
 
  /* SCOPE BANNER */
  .cal-scope-banner { display: flex; align-items: flex-start; gap: 14px; background: var(--dark); color: rgba(255,255,255,0.85); border-radius: 5px; padding: 16px 20px; font-size: 13px; line-height: 1.65; margin-bottom: 28px; }
  .cal-scope-banner strong { color: var(--white); }
  .cal-scope-banner .scope-icon { font-size: 20px; flex-shrink: 0; margin-top: 1px; }
 
  /* LEGEND */
  .cal-legend { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 28px; animation: fadeUp 0.5s ease both 0.15s; }
  .leg-item { display: flex; align-items: center; gap: 8px; font-size: 12.5px; font-weight: 700; letter-spacing: 0.3px; padding: 8px 16px; border-radius: 4px; cursor: pointer; transition: opacity 0.2s, box-shadow 0.2s; user-select: none; border: 2px solid transparent; }
  .leg-item.active { opacity: 1; box-shadow: 0 2px 8px rgba(0,0,0,0.12); }
  .leg-item.inactive { opacity: 0.55; }
  .leg-item:hover { opacity: 1; }
  .leg-dot { width: 11px; height: 11px; border-radius: 50%; flex-shrink: 0; }
  .leg-item.type-hard    { background: #FADADD; color: #7A0E1E; border-color: #F0B8BE; }
  .leg-item.type-action  { background: #FAE4CC; color: #7A3E0A; border-color: #F0C89A; }
  .leg-item.type-state   { background: #C8DEFA; color: #0D3D78; border-color: #96BDF5; }
  .leg-item.type-all     { background: var(--dark); color: var(--white); border-color: var(--dark); }
  .leg-item.type-all.inactive { background: var(--gray-lt); color: var(--dark); border-color: var(--gray-lt); }
  .leg-dot.hard   { background: #C01030; }
  .leg-dot.action { background: #A05010; }
  .leg-dot.state  { background: #1050A0; }
  .leg-dot.all    { background: var(--white); }
 
  /* QUARTER PILLS */
  .cal-quarters { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 36px; animation: fadeUp 0.5s ease both 0.2s; }
  .q-pill { font-size: 12px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; padding: 8px 18px; border-radius: 3px; border: 2px solid var(--gray-lt); cursor: pointer; transition: all 0.2s; background: var(--white); color: var(--gray); }
  .q-pill.active { background: var(--dark); color: var(--white); border-color: var(--dark); }
  .q-pill:hover:not(.active) { border-color: var(--accent); color: var(--accent); }
 
  /* SECTION LABELS */
  .cal-section-label { font-size: 10px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: var(--gray); padding: 6px 0; border-bottom: 1px solid var(--gray-lt); margin-bottom: 16px; margin-top: 8px; }
 
  /* ENTRIES */
  .cal-entries { display: flex; flex-direction: column; gap: 16px; }
  .cal-entry { background: var(--white); border-radius: 6px; overflow: hidden; box-shadow: 0 1px 6px rgba(27,58,75,0.07); transition: box-shadow 0.2s, transform 0.2s; animation: fadeUp 0.4s ease both; }
  .cal-entry:hover { box-shadow: 0 4px 20px rgba(27,58,75,0.12); transform: translateY(-1px); }
  .cal-entry.hard   { border-left: 5px solid var(--red); }
  .cal-entry.action { border-left: 5px solid var(--amber); }
  .cal-entry.state  { border-left: 5px solid var(--accent); }
  .cal-entry.hidden { display: none; }
 
  .entry-inner { padding: 22px 26px; }
  .entry-top { display: flex; align-items: flex-start; gap: 14px; margin-bottom: 14px; flex-wrap: wrap; }
  .entry-badge { font-size: 10px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; padding: 4px 10px; border-radius: 2px; flex-shrink: 0; margin-top: 2px; }
  .hard   .entry-badge { background: var(--red-bg);   color: var(--red);    }
  .action .entry-badge { background: var(--amber-bg); color: var(--amber);  }
  .state  .entry-badge { background: var(--blue-bg);  color: var(--accent); }
  .entry-title-block { flex: 1; min-width: 200px; }
  .entry-title { font-family: 'Fraunces', serif; font-size: 17px; font-weight: 700; color: var(--dark); line-height: 1.25; margin-bottom: 3px; }
  .entry-date { font-size: 12px; font-weight: 700; letter-spacing: 0.3px; }
  .hard   .entry-date { color: var(--red); }
  .action .entry-date { color: var(--amber); }
  .state  .entry-date { color: var(--accent); }
 
  .entry-body { font-size: 13.5px; line-height: 1.65; color: #555; margin-bottom: 14px; }
 
  .entry-state-note { font-size: 12.5px; color: var(--accent); background: var(--blue-bg); border-radius: 3px; padding: 10px 14px; margin-bottom: 14px; line-height: 1.55; }
  .entry-state-note strong { color: var(--dark); }
 
  .entry-ready { background: var(--gray-lt); border-radius: 4px; padding: 14px 16px; margin-bottom: 12px; }
  .entry-ready-label { font-size: 10px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--dark); margin-bottom: 8px; }
  .entry-ready ul { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 5px; }
  .entry-ready ul li { font-size: 13px; color: var(--body); padding-left: 18px; position: relative; }
  .entry-ready ul li::before { content: '→'; position: absolute; left: 0; color: var(--accent); font-size: 11px; top: 1px; }
 
  .entry-source { font-size: 11.5px; color: var(--gray); display: flex; align-items: flex-start; gap: 5px; flex-wrap: wrap; line-height: 1.5; }
  .entry-source strong { color: var(--dark); font-weight: 700; }
  .entry-source a { color: var(--accent); text-decoration: none; font-weight: 500; }
  .entry-source a:hover { text-decoration: underline; }
 
  /* STAT BAR */
  .cal-statbar { display: flex; background: var(--dark); border-radius: 6px; overflow: hidden; margin-top: 40px; animation: fadeUp 0.5s ease both 0.3s; }
  .cal-stat { flex: 1; padding: 22px 28px; border-right: 1px solid rgba(255,255,255,0.1); }
  .cal-stat:last-child { border-right: none; }
  .cal-stat-val { font-family: 'Fraunces', serif; font-size: 22px; font-weight: 700; color: var(--white); margin-bottom: 4px; }
  .cal-stat-lbl { font-size: 12px; color: rgba(255,255,255,0.5); line-height: 1.4; }
 
  /* FOOTER NOTE */
  .cal-footer-note { margin-top: 32px; padding: 20px 24px; background: var(--white); border-radius: 6px; border-left: 4px solid var(--amber); font-size: 13px; color: var(--gray); line-height: 1.65; animation: fadeUp 0.5s ease both 0.35s; }
  .cal-footer-note strong { color: var(--dark); }
  .cal-footer-note a { color: var(--accent); text-decoration: none; font-weight: 500; }
 
  @keyframes fadeUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
 
  @media (max-width: 600px) {
    .cal-wrap { padding: 32px 16px 48px; }
    .cal-statbar { flex-direction: column; }
    .cal-stat { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.1); }
    .cal-stat:last-child { border-bottom: none; }
    .cal-band { padding: 12px 20px; }
  }
</style>
</head>
<body>
 
<div class="cal-band">
  <div class="cal-band-inner">
    <span>Federal Compliance</span><span>〰</span><span class="hi">K-12 Intelligence</span><span>〰</span><span>Title I · II · III · IV-A</span><span>〰</span><span class="hi">FERPA · IDEA · McKinney-Vento</span><span>〰</span><span>The Language Firm</span><span>〰</span>
    <span>Federal Compliance</span><span>〰</span><span class="hi">K-12 Intelligence</span><span>〰</span><span>Title I · II · III · IV-A</span><span>〰</span><span class="hi">FERPA · IDEA · McKinney-Vento</span><span>〰</span><span>The Language Firm</span><span>〰</span>
  </div>
</div>
 
<div class="cal-wrap">
 
  <div class="cal-header">
    <div class="cal-eyebrow">The Language Firm: K-12 Compliance Intelligence</div>
    <h1 class="cal-title">Federal Compliance<br><em>Calendar</em></h1>
    <p class="cal-desc">Verified federal obligations, recommended internal actions, and "check your state" windows, each labeled honestly. No invented dates. Every entry cites its primary federal source.</p>
 
    <div class="cal-scope-banner">
      <span class="scope-icon">🇺🇸</span>
      <div>
        <strong>Federal law only. Applies to all 50 states.</strong> Every entry on this calendar is grounded in federal statute or regulation. "Hard deadline" entries reflect federal fiscal year dates and standing federal obligations. "Check your state" entries identify where your SEA sets the specific window. The federal hook is real and national, and the submission date varies by state. Your state education agency is always the authoritative source for exact local deadlines.
      </div>
    </div>
  </div>
 
  <div class="cal-legend">
    <div class="leg-item type-all active"     data-filter="all"    onclick="filterType('all')"><div class="leg-dot all"></div>All entries</div>
    <div class="leg-item type-hard inactive"   data-filter="hard"   onclick="filterType('hard')"><div class="leg-dot hard"></div>Hard deadline: verified federal date</div>
    <div class="leg-item type-action inactive" data-filter="action" onclick="filterType('action')"><div class="leg-dot action"></div>Recommended internal action</div>
    <div class="leg-item type-state inactive"  data-filter="state"  onclick="filterType('state')"><div class="leg-dot state"></div>Check your state: SEA sets the window</div>
  </div>
 
  <div class="cal-quarters">
    <div class="q-pill active" data-q="all" onclick="filterQ('all')">All quarters</div>
    <div class="q-pill" data-q="q1" onclick="filterQ('q1')">Q1 · Jan–Mar</div>
    <div class="q-pill" data-q="q2" onclick="filterQ('q2')">Q2 · Apr–Jun</div>
    <div class="q-pill" data-q="q3" onclick="filterQ('q3')">Q3 · Jul–Sep</div>
    <div class="q-pill" data-q="q4" onclick="filterQ('q4')">Q4 · Oct–Dec</div>
  </div>
 
  <div class="cal-entries" id="entries">
 
    <!-- ══ Q1 ══ -->
    <div class="cal-section-label">Q1: January through March</div>
 
    <!-- Title I Expenditure Pace -->
    <div class="cal-entry action" data-q="q1" data-type="action">
      <div class="entry-inner">
        <div class="entry-top">
          <div class="entry-badge">Internal Action</div>
          <div class="entry-title-block">
            <div class="entry-title">Title I Part A: Mid-Year Expenditure Pace Review</div>
            <div class="entry-date">Recommended: February through March. Not a federal filing date.</div>
          </div>
        </div>
        <p class="entry-body">ESSA §1127(a) limits Title I Part A carryover to 15% of a district's annual allocation. The carryover calculation is made at the close of the federal fiscal year (September 30), not at the end of the school year. A pace problem identified in February can still be corrected. One identified in August usually cannot. This is a recommended internal review, not a federal filing requirement.</p>
        <div class="entry-ready">
          <div class="entry-ready-label">What to review internally</div>
          <ul>
            <li>Pull current expenditure report against your total Title I Part A allocation</li>
            <li>Project forward to September 30: will unspent funds exceed 15%?</li>
            <li>Identify any delayed hires, postponed purchases, or unexpended reserves</li>
            <li>Document a corrective plan if pace is behind (fund redistribution, supplemental purchases)</li>
          </ul>
        </div>
        <div class="entry-source">
          <strong>Source:</strong> ESSA §1127(a) ·
          <a href="https://oese.ed.gov/offices/office-of-formula-grants/school-support-and-accountability/essa-legislation-table-contents/essa-legislation/" target="_blank">ESSA full text, ed.gov</a>
          · Hard federal date is September 30 FY close. This entry is a mid-year precaution.
        </div>
      </div>
    </div>
 
    <!-- ESSA Consolidated State Plan check -->
    <div class="cal-entry action" data-q="q1" data-type="action">
      <div class="entry-inner">
        <div class="entry-top">
          <div class="entry-badge">Internal Action</div>
          <div class="entry-title-block">
            <div class="entry-title">ESSA Consolidated State Plan: Local Program Alignment Review</div>
            <div class="entry-date">Recommended: January through February. No federal filing date for districts.</div>
          </div>
        </div>
        <p class="entry-body">Each state submits a Consolidated State Plan to ED under ESSA that governs how Title I, II, III, and IV-A funds flow to districts. Districts are bound by their state's approved plan, but most district administrators have never read it. Q1 is a practical time to verify that local program descriptions and use-of-funds plans remain consistent with what the state certified to ED. Misalignment discovered during a monitoring visit, rather than by the district, is a compliance finding.</p>
        <div class="entry-ready">
          <div class="entry-ready-label">What to review internally</div>
          <ul>
            <li>Locate your state's current ESSA Consolidated State Plan (available on your SEA's website)</li>
            <li>Review Title I supplement-not-supplant documentation against your local budget</li>
            <li>Confirm that funded Title II professional development activities match plan descriptions</li>
            <li>Check Title IV-A well-rounded education spending meets the 20% threshold requirement</li>
          </ul>
        </div>
        <div class="entry-source">
          <strong>Source:</strong>
          <a href="https://oese.ed.gov/offices/office-of-formula-grants/school-support-and-accountability/essa-legislation-table-contents/" target="_blank">ESSA, ed.gov/oese</a>
          · State plans publicly available at ed.gov/essa
        </div>
      </div>
    </div>
 
    <!-- ══ Q2 ══ -->
    <div class="cal-section-label">Q2: April through June</div>
 
    <!-- FERPA/PPRA compliance certification -->
    <div class="cal-entry hard" data-q="q2" data-type="hard">
      <div class="entry-inner">
        <div class="entry-top">
          <div class="entry-badge">Hard Deadline</div>
          <div class="entry-title-block">
            <div class="entry-title">FERPA &amp; PPRA Compliance Certification</div>
            <div class="entry-date">April 30, per ED Student Privacy Policy Office (SPPO) requirement</div>
          </div>
        </div>
        <p class="entry-body">On March 28, 2025, ED's Student Privacy Policy Office issued a Dear Colleague Letter alongside its annual FERPA/PPRA notification (required by 20 U.S.C. §1232h(c)(5)(C)), requiring each SEA to submit documentation by April 30, 2025 confirming that the SEA and its LEAs are complying with FERPA and PPRA. The April 30 date was tied to a specific 2025 enforcement cycle focused on parental rights and student records. ED has not confirmed this as a recurring annual deadline. Confirm with your SEA each spring whether a new compliance documentation request has been issued and what district-level response is required.</p>
        <div class="entry-ready">
          <div class="entry-ready-label">What to have ready</div>
          <ul>
            <li>FERPA annual notification: distributed, translated, and documented</li>
            <li>Directory information policy current and board-approved</li>
            <li>Records access request procedure documented and accessible to staff</li>
            <li>PPRA survey notification procedures in place for any third-party surveys</li>
            <li>Any "gender plan" or similar student-specific documentation reviewed for parental access compliance</li>
            <li>Confirm with your SEA what district-level documentation they require for certification</li>
          </ul>
        </div>
        <div class="entry-source">
          <strong>Source:</strong>
          <a href="https://studentprivacy.ed.gov/" target="_blank">ED Student Privacy Policy Office, studentprivacy.ed.gov</a>
          · FERPA: 20 U.S.C. §1232g; 34 CFR Part 99 · PPRA: 20 U.S.C. §1232h
          · Dear Colleague Letter issued March 28, 2025. April 30 was a 2025-specific date; confirm with your SEA whether a new request has been issued each spring.
        </div>
      </div>
    </div>
 
    <!-- FERPA annual notification -->
    <div class="cal-entry action" data-q="q2" data-type="action">
      <div class="entry-inner">
        <div class="entry-top">
          <div class="entry-badge">Internal Action</div>
          <div class="entry-title-block">
            <div class="entry-title">FERPA Annual Notification: Review and Distribute</div>
            <div class="entry-date">Recommended: May through June. No single federal filing date.</div>
          </div>
        </div>
        <p class="entry-body">34 CFR §99.7 requires LEAs to notify parents and eligible students of their FERPA rights annually. There is no prescribed federal date. The notification must be provided by any means reasonably likely to inform families, and must include provisions for families with disabilities or whose primary language is not English. End-of-year review ensures the notification is accurate and the distribution is documented before the new school year begins.</p>
        <div class="entry-ready">
          <div class="entry-ready-label">What to review and document</div>
          <ul>
            <li>Is the notification content current? (rights to inspect, amend, consent to disclosure, file complaint)</li>
            <li>Does it include the district's definition of "school official" and "legitimate educational interest"?</li>
            <li>Distribution method documented: how was it sent, to whom, and when?</li>
            <li>Available in all required home languages for your student population?</li>
            <li>Directory information opt-out process documented and accessible</li>
          </ul>
        </div>
        <div class="entry-source">
          <strong>Source:</strong>
          <a href="https://studentprivacy.ed.gov/ferpa" target="_blank">FERPA, studentprivacy.ed.gov</a>
          · 34 CFR §99.7 · Annual standing obligation; no single federal filing date
        </div>
      </div>
    </div>
 
    <!-- McKinney-Vento data -->
    <div class="cal-entry state" data-q="q2" data-type="state">
      <div class="entry-inner">
        <div class="entry-top">
          <div class="entry-badge">Check Your State</div>
          <div class="entry-title-block">
            <div class="entry-title">McKinney-Vento: Homeless Student Data Submission</div>
            <div class="entry-date">SEA sets the district window, typically spring. Verify annually with your SEA.</div>
          </div>
        </div>
        <div class="entry-state-note">
          <strong>Why "check your state":</strong> McKinney-Vento data (EDFacts file specs FS 118, FS 170, FS 194) flows from district to SEA to ED via the EDPass system. The SEA sets the district-level data collection window. FS 170 for SY 2024–25, for example, was due to ED by January 2026, but the district-to-SEA window that feeds it is set by each state individually. The federal obligation is national; the submission calendar is not.
        </div>
        <p class="entry-body">The McKinney-Vento Homeless Assistance Act (Title VII-B, 42 U.S.C. §11431–11435) requires annual data collection on homeless student identification, enrollment, transportation, and services. What a federal or state reviewer asks is whether every identified student has a complete record: dates of identification, services offered, barriers removed, and school-of-origin decisions documented. That question is constant regardless of when your state's window opens.</p>
        <div class="entry-ready">
          <div class="entry-ready-label">What to have ready before your SEA's window opens</div>
          <ul>
            <li>Identification logs: date identified, by whom, definition of homelessness applied</li>
            <li>Enrollment records: immediate enrollment documented, any barriers and how they were removed</li>
            <li>Transportation records for each student exercising school-of-origin rights</li>
            <li>Unaccompanied youth records and FAFSA status notifications (if applicable)</li>
            <li>Services-offered documentation for every identified student this year</li>
            <li>Liaison annual professional development participation documented (42 U.S.C. §11432(g)(6)(A)(ix))</li>
          </ul>
        </div>
        <div class="entry-source">
          <strong>Find your SEA's window:</strong>
          <a href="https://nche.ed.gov/" target="_blank">NCHE, nche.ed.gov</a>
          · Source: McKinney-Vento Act, Title VII-B; EDFacts FS 118, 170, 194
          · Liaison professional development: 42 U.S.C. §11432(f)(6) &amp; (g)(6)(A)(ix)
        </div>
      </div>
    </div>
 
    <!-- Title III EL program annual review -->
    <div class="cal-entry action" data-q="q2" data-type="action">
      <div class="entry-inner">
        <div class="entry-top">
          <div class="entry-badge">Internal Action</div>
          <div class="entry-title-block">
            <div class="entry-title">Title III EL Program: Annual Outcome Review</div>
            <div class="entry-date">Recommended: May through June. Federal accountability cycle begins here.</div>
          </div>
        </div>
        <p class="entry-body">ESSA §3121 requires Title III subgrantees to annually report EL student progress toward English proficiency and academic achievement. SEAs use this data to determine whether districts have met Title III accountability targets. Districts that fail to meet targets for two consecutive years face mandatory improvement plans. Q2 is when to review current-year outcome data, before the SEA's reporting window opens, so that findings don't arrive as surprises during monitoring.</p>
        <div class="entry-ready">
          <div class="entry-ready-label">What to review before the SEA reporting window</div>
          <ul>
            <li>EL student progress on English language proficiency assessments (ELPA) year-over-year</li>
            <li>Percentage of ELs reclassified as proficient: is the trend moving in the right direction?</li>
            <li>Title III-funded activity documentation: do records show a clear link between spending and outcomes?</li>
            <li>Parent notification: were parents of EL students notified within 30 days of placement (ESSA §1112(e)(3)(A))?</li>
          </ul>
        </div>
        <div class="entry-source">
          <strong>Source:</strong>
          <a href="https://oese.ed.gov/offices/office-of-formula-grants/english-learner-programs/" target="_blank">ED Title III Program, oese.ed.gov</a>
          · ESSA §3121 (accountability) · ESSA §1112(e)(3)(A) (parent notification)
        </div>
      </div>
    </div>
 
    <!-- ══ Q3 ══ -->
    <div class="cal-section-label">Q3: July through September</div>
 
    <!-- Title I carryover hard date -->
    <div class="cal-entry hard" data-q="q3" data-type="hard">
      <div class="entry-inner">
        <div class="entry-top">
          <div class="entry-badge">Hard Deadline</div>
          <div class="entry-title-block">
            <div class="entry-title">Title I Part A: 15% Carryover Limit</div>
            <div class="entry-date">September 30, federal fiscal year close (ESSA §1127(a))</div>
          </div>
        </div>
        <p class="entry-body">ESSA §1127(a) prohibits districts from carrying over more than 15% of their Title I Part A allocation from one fiscal year to the next. The calculation is made at the close of the federal fiscal year (September 30). Districts that exceed the 15% limit must document why and request a waiver from their SEA. Repeated carryover can trigger compliance monitoring. The mid-year pace review (see Q1 entry) exists specifically to prevent a problem at this date.</p>
        <div class="entry-ready">
          <div class="entry-ready-label">What to have documented by September 30</div>
          <ul>
            <li>Final expenditure report against total Title I Part A allocation</li>
            <li>Carryover calculation: confirm at or below 15% of annual allocation</li>
            <li>If above 15%: written justification drafted and submitted to your SEA</li>
            <li>Waiver documentation on file if SEA approval was obtained</li>
          </ul>
        </div>
        <div class="entry-source">
          <strong>Source:</strong> ESSA §1127(a) ·
          <a href="https://oese.ed.gov/offices/office-of-formula-grants/school-support-and-accountability/" target="_blank">ED Title I Program, oese.ed.gov</a>
          · This is the actual hard date, not a spring deadline
        </div>
      </div>
    </div>
 
    <!-- IDEA Part B -->
    <div class="cal-entry state" data-q="q3" data-type="state">
      <div class="entry-inner">
        <div class="entry-top">
          <div class="entry-badge">Check Your State</div>
          <div class="entry-title-block">
            <div class="entry-title">IDEA Part B: Annual Performance Data Collection</div>
            <div class="entry-date">SEA sets district data submission windows, feeding the state SPP/APR cycle</div>
          </div>
        </div>
        <div class="entry-state-note">
          <strong>Why "check your state":</strong> IDEA Part B annual performance data flows district → SEA → ED through each state's State Performance Plan and Annual Performance Report (SPP/APR) process. The SEA sets district-level data submission windows; there is no federal date that applies to districts directly. What is federal and uniform is what the data must show.
        </div>
        <p class="entry-body">IDEA Part B (20 U.S.C. §1412) requires annual data collection across 17 compliance and results indicators including IEP timelines, least restrictive environment (LRE) placements, transition services, and disproportionality. A federal reviewer's core questions: Were IEP evaluation timelines met? Are LRE placement decisions documented with individualized rationale? Are transition plans in place for all required students?</p>
        <div class="entry-ready">
          <div class="entry-ready-label">What to have ready</div>
          <ul>
            <li>IEP evaluation completion rate: initial evaluations completed within 60 days of consent (federal requirement)</li>
            <li>LRE placement data: documented rationale for each placement decision. Generic language is a finding.</li>
            <li>Transition plan documentation: in place for all students 16+ (IDEA). Check your state's age requirement.</li>
            <li>Disproportionality analysis completed. Significant disproportionality triggers corrective action.</li>
            <li>Prior Written Notice (PWN) on file for all IEP decisions made this year</li>
          </ul>
        </div>
        <div class="entry-source">
          <strong>Find your SEA's window:</strong>
          <a href="https://sites.ed.gov/idea/" target="_blank">IDEA, sites.ed.gov/idea</a>
          · 20 U.S.C. §1412 · SPP/APR indicators: 34 CFR §300.600–300.602
        </div>
      </div>
    </div>
 
    <!-- Title IV-A SSAE spending check -->
    <div class="cal-entry action" data-q="q3" data-type="action">
      <div class="entry-inner">
        <div class="entry-top">
          <div class="entry-badge">Internal Action</div>
          <div class="entry-title-block">
            <div class="entry-title">Title IV-A SSAE: Spending Threshold Verification</div>
            <div class="entry-date">Recommended: August through September, before fiscal year close</div>
          </div>
        </div>
        <p class="entry-body">ESSA §4105(b) requires districts receiving more than $30,000 in Title IV-A (Student Support and Academic Enrichment) funds to spend at least 20% on well-rounded educational opportunities, at least 20% on safe and healthy students activities, and no more than 15% on technology infrastructure. Districts that don't meet these thresholds can face findings during monitoring. September is the last opportunity to verify allocation percentages before fiscal year close.</p>
        <div class="entry-ready">
          <div class="entry-ready-label">What to verify before September 30</div>
          <ul>
            <li>Well-rounded education activities: at or above 20% of Title IV-A expenditures</li>
            <li>Safe and healthy students activities: at or above 20% of Title IV-A expenditures</li>
            <li>Technology infrastructure: at or below 15% of Title IV-A expenditures</li>
            <li>Activity documentation links each expenditure to an allowable use category</li>
          </ul>
        </div>
        <div class="entry-source">
          <strong>Source:</strong> ESSA §4105(b) ·
          <a href="https://oese.ed.gov/offices/office-of-formula-grants/well-rounded-educational-opportunities/student-support-and-academic-enrichment-program/" target="_blank">ED Title IV-A Program, oese.ed.gov</a>
        </div>
      </div>
    </div>
 
    <!-- ══ Q4 ══ -->
    <div class="cal-section-label">Q4: October through December</div>
 
    <!-- ESSA Consolidated Application / planning cycle -->
    <div class="cal-entry action" data-q="q4" data-type="action">
      <div class="entry-inner">
        <div class="entry-top">
          <div class="entry-badge">Internal Action</div>
          <div class="entry-title-block">
            <div class="entry-title">ESSA Program Planning: Next-Year Application Preparation</div>
            <div class="entry-date">Recommended: October through November. State application windows vary.</div>
          </div>
        </div>
        <p class="entry-body">Most SEAs open their consolidated application or funding request windows for the next school year in late winter or spring. Districts that begin preparation in Q4 (reviewing current-year program outcomes, documenting needs assessment findings, and updating use-of-funds narratives) submit stronger applications and avoid last-minute compliance gaps. This is a recommended internal action; your SEA's actual application window is the hard deadline to track.</p>
        <div class="entry-ready">
          <div class="entry-ready-label">What to prepare in Q4</div>
          <ul>
            <li>Current-year outcome data for each funded program: what worked, what did not</li>
            <li>Needs assessment documentation updated (required for Title I schoolwide programs)</li>
            <li>Use-of-funds narratives reviewed for supplement-not-supplant compliance</li>
            <li>Parent and family engagement plan reviewed and updated (Title I §1116)</li>
            <li>Verify authorized representative designation is current in your SEA's system</li>
          </ul>
        </div>
        <div class="entry-source">
          <strong>Source:</strong>
          <a href="https://oese.ed.gov/" target="_blank">ED Office of Elementary and Secondary Education, oese.ed.gov</a>
          · Check your SEA's website for the exact application window each year
        </div>
      </div>
    </div>
 
    <!-- AI Tool Governance -->
    <div class="cal-entry action" data-q="q4" data-type="action">
      <div class="entry-inner">
        <div class="entry-top">
          <div class="entry-badge">Internal Action</div>
          <div class="entry-title-block">
            <div class="entry-title">Annual AI Tool Governance Review</div>
            <div class="entry-date">Recommended: October through November. Not a regulatory deadline.</div>
          </div>
        </div>
        <p class="entry-body">No federal regulation currently requires an annual AI tool governance review. This is a recommended internal practice grounded in existing federal obligations: FERPA's data governance requirements apply to any tool that accesses student records (20 U.S.C. §1232g), COPPA applies to tools used with students under 13, and IDEA's confidentiality requirements apply to tools used in special education contexts. Q4 review ensures documentation is current before a new fiscal year of tool adoption begins.</p>
        <div class="entry-ready">
          <div class="entry-ready-label">What to review annually</div>
          <ul>
            <li>Complete inventory of AI tools in use, both approved and unapproved</li>
            <li>Confirm a signed Data Processing Agreement (DPA) exists for every tool that accesses student data</li>
            <li>Verify governing board approval is documented for each AI tool adoption</li>
            <li>Confirm vendor is still operational, relevant after recent edtech failures</li>
            <li>Output review policies current for all student-facing generative AI tools</li>
            <li>Incident response plan confirmed to include an AI-specific protocol</li>
          </ul>
        </div>
        <div class="entry-source">
          <strong>Federal basis:</strong>
          <a href="https://studentprivacy.ed.gov/" target="_blank">FERPA, studentprivacy.ed.gov</a>
          · 20 U.S.C. §1232g · COPPA: 15 U.S.C. §6501 · IDEA confidentiality: 34 CFR §300.610–300.626
          · CoSN Privacy Framework
        </div>
      </div>
    </div>
 
    <!-- Title II professional development check -->
    <div class="cal-entry state" data-q="q4" data-type="state">
      <div class="entry-inner">
        <div class="entry-top">
          <div class="entry-badge">Check Your State</div>
          <div class="entry-title-block">
            <div class="entry-title">Title II Part A: Professional Development Documentation</div>
            <div class="entry-date">SEA sets reporting windows. Federal allowability standard is uniform.</div>
          </div>
        </div>
        <div class="entry-state-note">
          <strong>Why "check your state":</strong> Title II Part A expenditure reporting flows through each state's consolidated reporting system on a schedule the SEA sets. The federal standard for what constitutes an allowable professional development expenditure is uniform; the reporting window and format are not.
        </div>
        <p class="entry-body">ESSA §2103 requires that Title II Part A funds be used for "high-quality professional development" as defined in §8101(42). Activities must be sustained, intensive, and classroom-focused, not one-day workshops. Reviewers ask whether districts can document that each expenditure meets the ESSA definition and was not used to supplant state or local professional development funding. Q4 is when to audit documentation before year-end reporting.</p>
        <div class="entry-ready">
          <div class="entry-ready-label">What to have documented</div>
          <ul>
            <li>For each Title II-funded activity: duration, content focus, and evidence of classroom application</li>
            <li>Supplement-not-supplant documentation: were these activities funded locally before Title II?</li>
            <li>Personnel paid with Title II funds: time and effort records current</li>
            <li>Needs assessment documented: Title II activities should connect to identified teacher/leader needs</li>
          </ul>
        </div>
        <div class="entry-source">
          <strong>Source:</strong> ESSA §2103 · ESSA §8101(42) (definition of high-quality PD) ·
          <a href="https://oese.ed.gov/offices/office-of-formula-grants/teachers-and-leaders/title-ii-part-a-supporting-effective-instruction/" target="_blank">ED Title II Program, oese.ed.gov</a>
          · Check your SEA for reporting window
        </div>
      </div>
    </div>
 
  </div><!-- /cal-entries -->
 
  <div class="cal-statbar">
    <div class="cal-stat">
      <div class="cal-stat-val">2 verified</div>
      <div class="cal-stat-lbl">Hard federal deadlines: September 30 FY close and April 30 FERPA/PPRA certification</div>
    </div>
    <div class="cal-stat">
      <div class="cal-stat-val">7 internal</div>
      <div class="cal-stat-lbl">Recommended actions grounded in federal obligation, labeled as practice not regulation</div>
    </div>
    <div class="cal-stat">
      <div class="cal-stat-val">3 state-set</div>
      <div class="cal-stat-lbl">"Check your state" entries: federal hook documented, SEA sets the window</div>
    </div>
  </div>
 
  <div class="cal-footer-note">
    <strong>About this calendar's accuracy standards.</strong> Every entry is grounded in federal statute or regulation, with no state-specific filing dates, no invented deadlines. "Hard deadline" entries reflect standing federal fiscal year dates or ED-issued certification requirements. "Check your state" entries identify where the federal obligation is real and national but the district-facing submission window is set by each SEA. "Recommended internal action" entries are labeled explicitly as practice, not regulation, with the federal provision that makes the practice consequential. Source citations are included on every entry.
  </div>
 
</div><!-- /cal-wrap -->
 
<script>
  let activeQ = 'all', activeType = 'all';
 
  function filterQ(q) {
    activeQ = q;
    document.querySelectorAll('.q-pill').forEach(p => p.classList.toggle('active', p.dataset.q === q));
    render();
  }
 
  function filterType(type) {
    activeType = type;
    document.querySelectorAll('.leg-item').forEach(l => {
      l.classList.toggle('active',   l.dataset.filter === type);
      l.classList.toggle('inactive', l.dataset.filter !== type);
    });
    render();
  }
 
  function render() {
    let delay = 0;
    document.querySelectorAll('.cal-entry').forEach(entry => {
      const show = (activeQ === 'all' || entry.dataset.q === activeQ) &&
                   (activeType === 'all' || entry.dataset.type === activeType);
      entry.classList.toggle('hidden', !show);
      if (show) {
        entry.style.animationDelay = (delay * 0.06) + 's';
        entry.style.animation = 'none';
        void entry.offsetHeight;
        entry.style.animation = '';
        delay++;
      }
    });
    document.querySelectorAll('.cal-section-label').forEach(label => {
      let next = label.nextElementSibling, hasVisible = false;
      while (next && !next.classList.contains('cal-section-label')) {
        if (next.classList.contains('cal-entry') && !next.classList.contains('hidden')) hasVisible = true;
        next = next.nextElementSibling;
      }
      label.style.display = hasVisible ? '' : 'none';
    });
  }
</script>
